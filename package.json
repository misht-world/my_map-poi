{
  "name": "my_map-poi",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Статическая карта значимых POI на Wikidata + Wikipedia + Commons (скоринг вместо ручной курации). См. SPEC.md.",
  "scripts": {
    "test": "node --test",
    "dev": "node scripts/serve.mjs",
    "data:dump": "curl -C - -L --retry 20 --retry-delay 10 -o D:/wikidata-dump/latest-all.json.gz https://dumps.wikimedia.org/wikidatawiki/entities/latest-all.json.gz",
    "data:repair": "node scripts/eu-00-download-dump.mjs",
    "data:parse": "node scripts/eu-01-parse-dump.mjs --region europe",
    "data:build-eu": "node scripts/eu-00-download-dump.mjs && node scripts/eu-01-parse-dump.mjs --region europe",
    "data:fetch": "node scripts/01-fetch-wikidata.mjs --region",
    "data:enrich": "node scripts/02-enrich.mjs",
    "data:classify": "node scripts/03-classify.mjs",
    "data:translate": "python scripts/translate_ru.py",
    "data:normalize": "node scripts/04-normalize.mjs",
    "data:enrich-eu": "node scripts/eu-03-enrich.mjs --min 5",
    "data:normalize-eu": "node scripts/eu-02-normalize.mjs"
  }
}
